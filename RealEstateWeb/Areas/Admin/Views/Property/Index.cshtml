@model IEnumerable<RealEstateWeb.Models.Property>

@{
    ViewData["Title"] = "Danh sách Bất động sản";
}

<h2>Quản lý Bất động sản</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm Bất động sản mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Tiêu đề</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Diện tích</th>
            <th>Người đăng</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Category.Name</td>
                <td>@item.Price.ToString("N0") VNĐ</td>
                <td>@item.Area m²</td>
                <td>@item.User.UserName</td>
                <td>
                    @(item.IsActive ? "Hiển thị" : "Đã ẩn")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>