@model IEnumerable<RealEstateWeb.Models.Property>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Bất Động Sản Nổi Bật</h1>
        <p class="lead text-muted">Khám phá những ngôi nhà và căn hộ tuyệt vời nhất dành cho bạn.</p>
    </div>

    <div class="card shadow-sm border-0 mb-5 rounded-4 bg-light">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-12 col-lg-4">
                    <label class="form-label fw-bold text-secondary">Tìm kiếm</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">🔍</span>
                        <input type="text" name="searchTerm" class="form-control border-start-0" placeholder="Nhập tên hoặc địa chỉ..." value="@ViewData["CurrentSearch"]">
                    </div>
                </div>

                <div class="col-6 col-lg-2">
                    <label class="form-label fw-bold text-secondary">Danh mục</label>
                    <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                        <option value="">Tất cả</option>
                    </select>
                </div>

                <div class="col-6 col-lg-2">
                    <label class="form-label fw-bold text-secondary">Giá từ</label>
                    <input type="number" name="minPrice" class="form-control" placeholder="VNĐ" value="@ViewData["CurrentMinPrice"]">
                </div>

                <div class="col-6 col-lg-2">
                    <label class="form-label fw-bold text-secondary">Đến giá</label>
                    <input type="number" name="maxPrice" class="form-control" placeholder="VNĐ" value="@ViewData["CurrentMaxPrice"]">
                </div>

                <div class="col-6 col-lg-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">
                        Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm property-card border-0">

                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/400x300?text=No+Image" : item.ImageUrl)"
                         class="card-img-top" alt="@item.Title" style="height: 220px; object-fit: cover;">

                    <div class="position-absolute top-0 end-0 m-2 badge bg-success fs-6 shadow">
                        @item.Category?.Name
                    </div>

                    <div class="card-body">
                        <h5 class="card-title text-truncate" title="@item.Title">@item.Title</h5>

                        <h5 class="card-subtitle mb-3 text-danger fw-bold">@item.Price.ToString("N0") VNĐ</h5>

                        <div class="d-flex justify-content-between text-muted small mb-3 pb-2 border-bottom">
                            <span><strong>Diện tích:</strong> @item.Area m²</span>
                            <span><strong>Ngày đăng:</strong> @item.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>

                        <p class="card-text text-secondary text-truncate-2" title="@item.Address">
                            📍 @item.Address
                        </p>
                    </div>

                    <div class="card-footer bg-white border-0 pb-3 pt-0">
                        <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 fw-bold">
                            Xem Chi Tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div> @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-5 mb-5">
            <ul class="pagination justify-content-center pagination-lg">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link shadow-sm" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-searchTerm="@ViewData["CurrentSearch"]"
                       asp-route-categoryId="@ViewData["CurrentCategory"]"
                       asp-route-minPrice="@ViewData["CurrentMinPrice"]"
                       asp-route-maxPrice="@ViewData["CurrentMaxPrice"]">
                        &laquo; Trước
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link shadow-sm" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchTerm="@ViewData["CurrentSearch"]"
                           asp-route-categoryId="@ViewData["CurrentCategory"]"
                           asp-route-minPrice="@ViewData["CurrentMinPrice"]"
                           asp-route-maxPrice="@ViewData["CurrentMaxPrice"]">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link shadow-sm" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-searchTerm="@ViewData["CurrentSearch"]"
                       asp-route-categoryId="@ViewData["CurrentCategory"]"
                       asp-route-minPrice="@ViewData["CurrentMinPrice"]"
                       asp-route-maxPrice="@ViewData["CurrentMaxPrice"]">
                        Sau &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
<style>
    .property-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 10px;
        overflow: hidden;
    }

        .property-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,.15) !important;
        }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>